{
  "name": "ddg-search-mcp",
  "version": "1.1.0",
  "description": "MCP server for DuckDuckGo search — free AI answers, web search, news, and content fetch. No API key needed.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "ddg-search-mcp": "./dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "duckduckgo",
    "mcp",
    "model-context-protocol",
    "search",
    "ai-answers",
    "web-search",
    "claude",
    "exa-alternative"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hung319/duck-mcp"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
